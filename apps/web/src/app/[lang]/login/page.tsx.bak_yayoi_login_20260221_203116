"use client";

import * as React from "react";
import { useRouter, useParams } from "next/navigation";

type Lang = "ja" | "en" | "zh-CN" | "zh-TW";

const LABEL: Record<Lang, { title: string; user: string; pass: string; btn: string; helper: string; firstTitle: string; firstDesc: string; firstBtn: string; support: string; forgot: string; errInvalid: string; }> = {
  ja: {
    title: "ログイン",
    user: "ユーザー名（メールアドレス）",
    pass: "パスワード",
    btn: "ログイン",
    helper: "ユーザー名（メールアドレス）とパスワードを入力して「ログイン」をクリックしてください。",
    firstTitle: "はじめてご利用のお客さま",
    firstDesc: "アカウントをお持ちでない方は、こちらからご登録ください。",
    firstBtn: "新規登録（準備中）",
    support: "サポート",
    forgot: "パスワードをお忘れですか？",
    errInvalid: "ログインに失敗しました。入力内容をご確認ください。",
  },
  en: {
    title: "Sign in",
    user: "Username (Email)",
    pass: "Password",
    btn: "Sign in",
    helper: "Enter your username (email) and password, then click “Sign in”.",
    firstTitle: "New here?",
    firstDesc: "If you don’t have an account, you can register here.",
    firstBtn: "Create account (Coming soon)",
    support: "Support",
    forgot: "Forgot password?",
    errInvalid: "Sign-in failed. Please check your credentials.",
  },
  "zh-CN": {
    title: "登录",
    user: "用户名（邮箱）",
    pass: "密码",
    btn: "登录",
    helper: "请输入用户名（邮箱）与密码，然后点击“登录”。",
    firstTitle: "首次使用的用户",
    firstDesc: "还没有账号？可从这里注册。",
    firstBtn: "注册（开发中）",
    support: "支持",
    forgot: "忘记密码？",
    errInvalid: "登录失败，请检查账号或密码。",
  },
  "zh-TW": {
    title: "登入",
    user: "使用者名稱（Email）",
    pass: "密碼",
    btn: "登入",
    helper: "請輸入使用者名稱（Email）與密碼，然後點擊「登入」。",
    firstTitle: "第一次使用的用戶",
    firstDesc: "還沒有帳號？可從這裡註冊。",
    firstBtn: "註冊（開發中）",
    support: "支援",
    forgot: "忘記密碼？",
    errInvalid: "登入失敗，請檢查帳號或密碼。",
  },
};

function cls(...xs: Array<string | false | undefined | null>) {
  return xs.filter(Boolean).join(" ");
}

export default function LoginPage() {
  const router = useRouter();
  const params = useParams();
  const currentLang = (params?.lang as Lang) || "ja";
  const t = LABEL[currentLang] ?? LABEL.ja;

  const [username, setUsername] = React.useState("");
  const [password, setPassword] = React.useState("");
  const [loading, setLoading] = React.useState(false);
  const [err, setErr] = React.useState<string | null>(null);

  async function onSubmit(e: React.FormEvent) {
    e.preventDefault();
    setErr(null);
    setLoading(true);

    try {
      // ✅ 这里默认对接你现有的登录 API（常见为 /api/auth/login）
      // 如果你后端路径不同：把 url 改成你的实际 endpoint 即可
      const r = await fetch("/api/auth/login", {
        method: "POST",
        headers: { "content-type": "application/json" },
        body: JSON.stringify({ email: username, password }),
      });

      if (!r.ok) {
        throw new Error(`${r.status} ${await r.text().catch(() => "")}`.trim());
      }

      const data = await r.json().catch(() => ({} as any));
      const token = data?.token || data?.access_token || data?.accessToken;

      if (!token) {
        // 兼容：如果后端直接 set-cookie 也行；这里给出友好提示
        // 但你目前系统用 localStorage('ls_token') 的概率更大
        throw new Error("NO_TOKEN");
      }

      localStorage.setItem("ls_token", token);
      router.push(`/${currentLang}/app`);
    } catch (e: any) {
      setErr(t.errInvalid);
      console.error("login failed:", e);
    } finally {
      setLoading(false);
    }
  }

  return (
    <div className="min-h-screen bg-[#fbf7f2]">
      {/* Top header (Yayoi-like) */}
      <header className="h-14 border-b border-black/10 bg-white">
        <div className="mx-auto flex h-full max-w-6xl items-center justify-between px-4">
          <div className="flex items-center gap-3">
            <div className="text-2xl font-extrabold tracking-tight text-[#1b4db3]">LedgerSeiri</div>
            <div className="text-lg font-semibold text-slate-800">マイポータル</div>
          </div>
          <a
            href="#"
            className="inline-flex items-center gap-2 text-sm font-medium text-[#1b4db3] hover:opacity-80"
          >
            <span className="inline-flex h-6 w-6 items-center justify-center rounded-full border border-[#1b4db3]/30 bg-[#1b4db3]/5">
              ?
            </span>
            {t.support}
          </a>
        </div>
      </header>

      <main className="mx-auto grid max-w-6xl gap-8 px-4 py-10 lg:grid-cols-1">
        {/* Login card */}
        <section className="mx-auto w-full max-w-[720px]">
          <div className="rounded-md border border-black/10 bg-white shadow-[0_10px_30px_rgba(0,0,0,0.08)]">
            <div className="px-10 py-8">
              <h1 className="text-center text-2xl font-bold text-slate-900">{t.title}</h1>
              <p className="mt-3 text-center text-sm text-slate-600">{t.helper}</p>

              <form onSubmit={onSubmit} className="mt-7 space-y-5">
                <div>
                  <label className="block text-sm font-medium text-slate-800">{t.user}</label>
                  <input
                    className="mt-2 h-12 w-full rounded border border-slate-400 bg-[#eaf1ff] px-4 text-sm outline-none focus:border-[#1b4db3] focus:ring-2 focus:ring-[#1b4db3]/15"
                    value={username}
                    onChange={(e) => setUsername(e.target.value)}
                    autoComplete="username"
                    inputMode="email"
                    placeholder="example@company.com"
                  />
                </div>

                <div>
                  <label className="block text-sm font-medium text-slate-800">{t.pass}</label>
                  <input
                    className="mt-2 h-12 w-full rounded border border-slate-400 bg-[#eaf1ff] px-4 text-sm outline-none focus:border-[#1b4db3] focus:ring-2 focus:ring-[#1b4db3]/15"
                    type="password"
                    value={password}
                    onChange={(e) => setPassword(e.target.value)}
                    autoComplete="current-password"
                    placeholder="••••••••"
                  />
                  <div className="mt-2 text-right">
                    <a href="#" className="text-sm text-[#1b4db3] hover:underline">
                      {t.forgot}
                    </a>
                  </div>
                </div>

                {err && (
                  <div className="rounded border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700">
                    {err}
                  </div>
                )}

                <button
                  type="submit"
                  disabled={loading || !username || !password}
                  className={cls(
                    "relative mt-1 h-12 w-full rounded bg-[#3f6fbf] text-white font-semibold shadow-sm",
                    "hover:brightness-[0.98] active:brightness-[0.96]",
                    "disabled:cursor-not-allowed disabled:opacity-60"
                  )}
                >
                  <span className="absolute right-4 top-1/2 -translate-y-1/2 inline-flex h-7 w-7 items-center justify-center rounded-full bg-white/15">
                    ›
                  </span>
                  {loading ? "..." : t.btn}
                </button>
              </form>
            </div>
          </div>

          {/* First time card */}
          <div className="mt-10 rounded-md border border-black/10 bg-white shadow-[0_10px_30px_rgba(0,0,0,0.06)]">
            <div className="px-10 py-8 text-center">
              <h2 className="text-xl font-bold text-slate-900">{t.firstTitle}</h2>
              <p className="mt-3 text-sm text-slate-600">{t.firstDesc}</p>
              <button
                type="button"
                className="relative mt-6 h-12 w-full max-w-[420px] rounded bg-[#3f6fbf] text-white font-semibold shadow-sm hover:brightness-[0.98]"
                onClick={() => alert("Coming soon")}
              >
                <span className="absolute right-4 top-1/2 -translate-y-1/2 inline-flex h-7 w-7 items-center justify-center rounded-full bg-white/15">
                  ›
                </span>
                {t.firstBtn}
              </button>

              <div className="mt-5">
                <a href="#" className="inline-flex items-center gap-2 text-sm text-[#1b4db3] hover:underline">
                  <span className="inline-flex h-5 w-5 items-center justify-center rounded-full border border-[#1b4db3]/30 bg-[#1b4db3]/5">?</span>
                  {currentLang === "ja" ? "LedgerSeiri IDとは" : "What is LedgerSeiri ID?"}
                </a>
              </div>
            </div>
          </div>
        </section>
      </main>

      <footer className="border-t border-black/10 bg-white py-6">
        <div className="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-3 px-4 text-sm text-slate-500">
          <div className="flex flex-wrap gap-x-4 gap-y-2">
            <a className="hover:underline" href="#">プライバシーポリシー</a>
            <a className="hover:underline" href="#">免責事項</a>
            <a className="hover:underline" href="#">お問い合わせ</a>
            <a className="hover:underline" href="#">利用規約</a>
            <a className="hover:underline" href="#">稼働状況</a>
          </div>
          <div>Copyright © LedgerSeiri</div>
        </div>
      </footer>
    </div>
  );
}
