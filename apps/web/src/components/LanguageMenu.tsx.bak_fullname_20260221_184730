"use client";

import { useEffect, useMemo, useRef, useState } from "react";
import { usePathname } from "next/navigation";

type LangCode = "ja" | "en" | "zh-CN" | "zh-TW";

const LABEL: Record<LangCode, string> = {
  ja: "JA",
  en: "EN",
  "zh-CN": "ZH-CN",
  "zh-TW": "ZH-TW",
};

function getLangFromPath(pathname: string): LangCode {
  const seg = (pathname.split("/")[1] || "ja") as LangCode;
  return seg === "ja" || seg === "en" || seg === "zh-CN" || seg === "zh-TW" ? seg : "ja";
}

function swapLang(pathname: string, next: LangCode) {
  const parts = pathname.split("/");
  const seg = parts[1];
  const hasLang = seg === "ja" || seg === "en" || seg === "zh-CN" || seg === "zh-TW";
  if (hasLang) parts[1] = next;
  else parts.splice(1, 0, next);
  return parts.join("/") || `/${next}`;
}

export default function LanguageMenu({ label = "言語" }: { label?: string }) {
  const pathname = usePathname() || "/ja/app";
  const current = useMemo(() => getLangFromPath(pathname), [pathname]);

  const [open, setOpen] = useState(false);
  const ref = useRef<HTMLDivElement | null>(null);

  useEffect(() => {
    const onDown = (e: MouseEvent) => {
      if (!open) return;
      const el = ref.current;
      if (!el) return;
      if (e.target instanceof Node && !el.contains(e.target)) setOpen(false);
    };
    const onKey = (e: KeyboardEvent) => {
      if (!open) return;
      if (e.key === "Escape") setOpen(false);
    };
    document.addEventListener("mousedown", onDown);
    document.addEventListener("keydown", onKey);
    return () => {
      document.removeEventListener("mousedown", onDown);
      document.removeEventListener("keydown", onKey);
    };
  }, [open]);

  const go = (next: LangCode) => {
    setOpen(false);
    window.location.href = swapLang(pathname, next);
  };

  return (
    <div ref={ref} className="relative inline-block">
      <button
        type="button"
        onClick={() => setOpen((v) => !v)}
        className="inline-flex items-center gap-2 rounded-xl border border-black/20 bg-white px-4 py-2 text-sm hover:bg-black/[0.03]"
      >
        <span className="inline-flex h-6 w-6 items-center justify-center rounded-full border border-black/10 bg-white">
          🌐
        </span>
        <span>{label}</span>
        <span className="rounded-lg bg-black/[0.04] px-2 py-0.5 text-xs">{LABEL[current]}</span>
        <span className="text-xs opacity-60">▾</span>
      </button>

      {open && (
        <div className="absolute right-0 top-full mt-2 w-44 overflow-hidden rounded-xl border border-black/10 bg-white shadow-lg z-[9999]">
          <button
            className="block w-full px-4 py-2 text-left text-sm hover:bg-black/[0.04]"
            onClick={() => go("en")}
          >
            English
          </button>
          <button
            className="block w-full px-4 py-2 text-left text-sm hover:bg-black/[0.04]"
            onClick={() => go("zh-CN")}
          >
            简体中文
          </button>
          <button
            className="block w-full px-4 py-2 text-left text-sm hover:bg-black/[0.04]"
            onClick={() => go("zh-TW")}
          >
            繁體中文
          </button>
          <button
            className="block w-full px-4 py-2 text-left text-sm hover:bg-black/[0.04]"
            onClick={() => go("ja")}
          >
            日本語
          </button>
        </div>
      )}
    </div>
  );
}
