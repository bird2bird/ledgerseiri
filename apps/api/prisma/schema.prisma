generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  password            String
  companyId           String?
  company             Company?             @relation(fields: [companyId], references: [id])
  createdAt           DateTime             @default(now())
  lastLoginAt         DateTime?
  lastLoginIp         String?
  // Refresh token sessions (opposite side of RefreshSession.user)
  refreshSessions     RefreshSession[]
  passwordResetTokens PasswordResetToken[]
  loginEvents         UserLoginEvent[]
}

model Company {
  status CompanyStatus @default(ACTIVE)

  id               String   @id @default(cuid())
  name             String
  fiscalMonthStart Int      @default(1)
  timezone         String   @default("Asia/Tokyo")
  currency         String   @default("JPY")
  users            User[]
  stores           Store[]
  createdAt        DateTime @default(now())

  subscription          WorkspaceSubscription?
  transactions          Transaction[]
  accounts              Account[]
  fundTransfers         FundTransfer[]
  transactionCategories TransactionCategory[]
  products              Product[]
  productSkus           ProductSku[]
  inventoryBalances     InventoryBalance[]
  inventoryMovements    InventoryMovement[]
  invoices              Invoice[]
  paymentReceipts       PaymentReceipt[]
  importJobs            ImportJob[]
  importStagingRows     ImportStagingRow[]
  exportJobs            ExportJob[]
}

model Store {
  id        String   @id @default(cuid())
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  name      String
  platform  String   @default("AMAZON")
  region    String   @default("JP")
  createdAt DateTime @default(now())

  transactions Transaction[]
  accounts     Account[]
  productSkus  ProductSku[]
  invoices     Invoice[]

  @@index([companyId])
}

enum TransactionType {
  SALE
  FBA_FEE
  AD
  REFUND
  OTHER
}

enum AccountType {
  BANK
  CASH
  EWALLET
  PAYMENT_GATEWAY
  OTHER
}

enum TransactionDirection {
  INCOME
  EXPENSE
  TRANSFER
}

enum TransactionSourceType {
  MANUAL
  STORE_ORDER
  INVOICE_PAYMENT
  IMPORT
  SYSTEM
}

enum InventoryMovementType {
  IN
  OUT
  ADJUST
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELED
}

enum JobStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
}

model Transaction {
  id         String  @id @default(cuid())
  companyId  String?
  storeId    String
  accountId  String?
  categoryId String?

  company   Company?             @relation(fields: [companyId], references: [id])
  store     Store                @relation(fields: [storeId], references: [id])
  account   Account?             @relation(fields: [accountId], references: [id], onDelete: SetNull)
  category  TransactionCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  importJob ImportJob?           @relation(fields: [importJobId], references: [id], onDelete: SetNull)

  type        TransactionType
  direction   TransactionDirection?
  sourceType  TransactionSourceType @default(MANUAL)
  amount      Int
  currency    String                @default("JPY")
  occurredAt  DateTime
  externalRef String?
  memo        String?

  businessMonth  String?
  dedupeHash     String?
  importJobId    String?
  sourceFileName String?
  sourceRowNo    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, occurredAt])
  @@index([storeId, occurredAt])
  @@index([accountId, occurredAt])
  @@index([categoryId])
  @@index([type])
  @@index([direction])
  @@index([importJobId])
  @@index([companyId, businessMonth])
  @@index([companyId, dedupeHash])
}

model Account {
  id             String      @id @default(cuid())
  companyId      String
  storeId        String?
  name           String
  type           AccountType @default(BANK)
  currency       String      @default("JPY")
  openingBalance Int         @default(0)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: SetNull)

  transactions Transaction[]
  transfersOut FundTransfer[]   @relation("TransferFromAccount")
  transfersIn  FundTransfer[]   @relation("TransferToAccount")
  payments     PaymentReceipt[]

  @@index([companyId])
  @@index([storeId])
}

model FundTransfer {
  id            String   @id @default(cuid())
  companyId     String
  fromAccountId String
  toAccountId   String
  amount        Int
  currency      String   @default("JPY")
  occurredAt    DateTime
  memo          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company     Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  fromAccount Account @relation("TransferFromAccount", fields: [fromAccountId], references: [id], onDelete: Cascade)
  toAccount   Account @relation("TransferToAccount", fields: [toAccountId], references: [id], onDelete: Cascade)

  @@index([companyId, occurredAt])
  @@index([fromAccountId])
  @@index([toAccountId])
}

model TransactionCategory {
  id        String               @id @default(cuid())
  companyId String
  name      String
  direction TransactionDirection
  code      String?
  isSystem  Boolean              @default(false)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@index([companyId, direction])
}

model Product {
  id        String   @id @default(cuid())
  companyId String
  name      String
  brand     String?
  category  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  skus    ProductSku[]

  @@index([companyId])
}

model ProductSku {
  id         String   @id @default(cuid())
  companyId  String
  productId  String
  storeId    String?
  skuCode    String
  name       String?
  costAmount Int?
  salePrice  Int?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  store   Store?  @relation(fields: [storeId], references: [id], onDelete: SetNull)

  balances  InventoryBalance[]
  movements InventoryMovement[]

  @@unique([companyId, skuCode])
  @@index([companyId])
  @@index([productId])
  @@index([storeId])
}

model InventoryBalance {
  id          String   @id @default(cuid())
  companyId   String
  skuId       String
  quantity    Int      @default(0)
  reservedQty Int      @default(0)
  alertLevel  Int      @default(0)
  updatedAt   DateTime @updatedAt

  company Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sku     ProductSku @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@unique([companyId, skuId])
}

model InventoryMovement {
  id         String                @id @default(cuid())
  companyId  String
  skuId      String
  type       InventoryMovementType
  quantity   Int
  occurredAt DateTime
  memo       String?
  createdAt  DateTime              @default(now())

  company Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sku     ProductSku @relation(fields: [skuId], references: [id], onDelete: Cascade)

  @@index([companyId, occurredAt])
  @@index([skuId, occurredAt])
}

model Invoice {
  id           String        @id @default(cuid())
  companyId    String
  storeId      String?
  invoiceNo    String
  customerName String
  issueDate    DateTime
  dueDate      DateTime
  currency     String        @default("JPY")
  totalAmount  Int
  paidAmount   Int           @default(0)
  status       InvoiceStatus @default(DRAFT)
  memo         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  company  Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  store    Store?           @relation(fields: [storeId], references: [id], onDelete: SetNull)
  payments PaymentReceipt[]

  @@unique([companyId, invoiceNo])
  @@index([companyId, issueDate])
  @@index([status])
}

model PaymentReceipt {
  id         String   @id @default(cuid())
  companyId  String
  invoiceId  String
  accountId  String?
  amount     Int
  currency   String   @default("JPY")
  receivedAt DateTime
  memo       String?
  createdAt  DateTime @default(now())

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  account Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([companyId, receivedAt])
  @@index([invoiceId])
}

model ImportJob {
  id         String    @id @default(cuid())
  companyId  String
  domain     String
  module     String?
  sourceType String?
  filename   String
  fileHash   String?
  status     JobStatus @default(PENDING)

  monthConflictPolicy String?
  totalRows           Int?
  successRows         Int?
  failedRows          Int?
  deletedRowCount     Int?    @default(0)

  fileMonthsJson     Json?
  conflictMonthsJson Json?

  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  importedAt   DateTime?

  company      Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stagingRows  ImportStagingRow[]
  transactions Transaction[]

  @@index([companyId, createdAt])
  @@index([domain, status])
  @@index([companyId, module, createdAt])
}

model ImportStagingRow {
  id                    String   @id @default(cuid())
  importJobId           String
  companyId             String
  module                String
  rowNo                 Int
  businessMonth         String?
  rawPayloadJson        Json
  normalizedPayloadJson Json
  dedupeHash            String?
  matchStatus           String
  matchReason           String?
  targetEntityType      String?
  targetEntityId        String?
  createdAt             DateTime @default(now())

  importJob ImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, module, businessMonth])
  @@index([importJobId, matchStatus])
  @@index([companyId, dedupeHash])
}

model ExportJob {
  id           String    @id @default(cuid())
  companyId    String
  domain       String
  format       String
  status       JobStatus @default(PENDING)
  filterJson   Json?
  fileUrl      String?
  errorMessage String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, createdAt])
  @@index([domain, status])
}

model RefreshSession {
  id            String    @id @default(cuid())
  userId        String
  jti           String    @unique
  createdAt     DateTime  @default(now())
  expiresAt     DateTime
  revokedAt     DateTime?
  replacedByJti String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

/// Keep connect-pg-simple table in DB (do NOT let prisma db push drop it)
model PgSession {
  sid    String   @id @db.VarChar
  sess   Json     @db.Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "IDX_session_expire")
  @@map("session")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  createdAt DateTime  @default(now())
  expiresAt DateTime
  usedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model UserLoginEvent {
  id            String   @id @default(cuid())
  userId        String
  loggedInAt    DateTime @default(now())
  ipAddress     String?
  userAgent     String?
  loginMethod   String   @default("password")
  success       Boolean  @default(true)
  failureReason String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedInAt])
  @@index([loggedInAt])
}

model LpVisitEvent {
  id          String   @id @default(cuid())
  path        String
  locale      String?
  eventType   String   @default("view")
  ctaName     String?
  referrer    String?
  visitorId   String?
  sessionId   String?
  ipAddress   String?
  userAgent   String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([path, createdAt])
  @@index([eventType, createdAt])
  @@index([locale, createdAt])
  @@index([visitorId, createdAt])
  @@index([sessionId, createdAt])
}

model LpConversionEvent {
  id        String   @id @default(cuid())
  eventType String
  email     String?
  userId    String?
  ctaName   String?
  source    String?
  locale    String?
  referrer  String?
  visitorId String?
  sessionId String?
  path      String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([eventType, createdAt])
  @@index([ctaName, createdAt])
  @@index([source, createdAt])
  @@index([locale, createdAt])
  @@index([visitorId, createdAt])
  @@index([sessionId, createdAt])
}

enum PlanCode {
  STARTER
  STANDARD
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}

model WorkspaceSubscription {
  id        String             @id @default(cuid())
  companyId String             @unique
  planCode  PlanCode           @default(STARTER)
  status    SubscriptionStatus @default(ACTIVE)

  currentPeriodEnd    DateTime?
  maxStores           Int       @default(1)
  invoiceStorageMb    Int       @default(200)
  aiChatMonthly       Int       @default(0)
  aiInvoiceOcrMonthly Int       @default(0)

  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([planCode])
  @@index([status])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

model ReconciliationDecision {
  id             String   @id @default(cuid())
  companyId      String
  candidateId    String
  decision       String
  persistenceKey String   @unique
  confidence     Float
  submittedAt    DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([submittedAt])
  @@index([companyId])
  @@index([companyId, submittedAt])
}

model ReconciliationDecisionAudit {
  id             String   @id @default(cuid())
  companyId      String
  candidateId    String
  persistenceKey String?
  actionType     String
  previousValue  String?
  nextValue      String?
  source         String
  createdAt      DateTime @default(now())

  @@index([companyId])
  @@index([companyId, createdAt])
  @@index([candidateId])
  @@index([persistenceKey])
}

model PlatformAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  sessions PlatformAdminSession[]
}

model PlatformAdminSession {
  id               String    @id @default(cuid())
  adminId          String
  refreshTokenHash String
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  admin PlatformAdmin @relation(fields: [adminId], references: [id])
}

enum CompanyStatus {
  ACTIVE
  SUSPENDED
}

model BillingWebhookEvent {
  id          String    @id
  type        String
  source      String    @default("stripe")
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([type])
  @@index([createdAt])
  @@index([processedAt])
}

enum PlatformOperationType {
  RECONCILIATION_BATCH_OVERRIDE
  TENANT_SUSPEND
  TENANT_ACTIVATE
  USER_ASSIGN
  USER_UNASSIGN
}

enum PlatformOperationScope {
  RECONCILIATION
  PLATFORM_TENANT
  PLATFORM_USER
}

enum PlatformOperationStatus {
  PENDING
  RUNNING
  COMPLETED
  PARTIAL_FAILED
  FAILED
}

enum PlatformOperationItemStatus {
  SUCCEEDED
  FAILED
  SKIPPED
}

model PlatformOperation {
  id     String                  @id @default(cuid())
  type   PlatformOperationType
  scope  PlatformOperationScope
  status PlatformOperationStatus @default(PENDING)

  requestedDecision     String?
  requestedByAdminId    String?
  requestedByAdminEmail String?

  companyId      String?
  candidateId    String?
  persistenceKey String?

  source       String?
  note         String?
  metadataJson Json?

  requestedCount Int @default(0)
  successCount   Int @default(0)
  failedCount    Int @default(0)

  requestedAt DateTime  @default(now())
  completedAt DateTime?

  items PlatformOperationItem[]

  @@index([type, requestedAt])
  @@index([scope, requestedAt])
  @@index([status, requestedAt])
  @@index([companyId, requestedAt])
}

model PlatformOperationItem {
  id          String            @id @default(cuid())
  operationId String
  operation   PlatformOperation @relation(fields: [operationId], references: [id], onDelete: Cascade)

  targetType String
  targetId   String

  companyId      String?
  candidateId    String?
  persistenceKey String?

  requestedAction String
  beforeValue     String?
  afterValue      String?

  status         PlatformOperationItemStatus
  failureCode    String?
  failureMessage String?

  auditId     String?
  processedAt DateTime @default(now())

  @@index([operationId])
  @@index([status, processedAt])
  @@index([targetId])
  @@index([companyId, processedAt])
}
