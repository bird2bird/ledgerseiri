import type { Request, Response } from 'express';
import Csrf from 'csrf';

/**
 * CSRF uses session ONLY to bind secret.
 * Session is NOT used for authentication anymore.
 */
export function csrfTokenHandler(req: Request, res: Response) {
  const sess: any = (req as any).session;
  if (!sess) {
    return res.status(500).json({ message: 'SESSION_NOT_READY' });
  }

  const csrf = new Csrf();

  if (!sess.csrfSecret) {
    sess.csrfSecret = csrf.secretSync();
  }

  const token = csrf.create(sess.csrfSecret);

  sess.save((err: any) => {
    if (err) {
      return res.status(500).json({ message: 'SESSION_SAVE_FAILED' });
    }
    res.setHeader('Cache-Control', 'no-store');
    return res.json({ csrfToken: token });
  });
}

export function verifyCsrf(req: Request): boolean {
  const sess: any = (req as any).session;
  if (!sess?.csrfSecret) return false;

  const token =
    (req.headers['x-csrf-token'] as string | undefined) ||
    (req.body?.csrfToken as string | undefined);

  if (!token) return false;

  const csrf = new Csrf();
  return csrf.verify(sess.csfSecret ?? sess.csrfSecret, token);
}
