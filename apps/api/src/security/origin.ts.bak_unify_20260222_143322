import type { Request, Response, NextFunction } from 'express';

function getAllowedOrigins(): string[] {
  const raw =
    process.env.ALLOWED_ORIGINS ||
    'https://www.ledgerseiri.com,https://ledgerseiri.com';
  return raw
    .split(',')
    .map((s) => s.trim())
    .filter(Boolean);
}

/**
 * Unified origin check:
 * - Browser requests usually have Origin or Referer -> must match allowlist
 * - Server-to-server / SSR often has NO Origin/Referer -> allow
 */
export function isAllowedRequestOrigin(req: Request): boolean {
  const allowed = getAllowedOrigins();
  const origin = req.headers.origin ? String(req.headers.origin) : '';
  const referer = req.headers.referer ? String(req.headers.referer) : '';

  // allow internal/SSR calls where Origin/Referer are absent
  if (!origin && !referer) return true;

  return (
    (origin && allowed.includes(origin)) ||
    (referer && allowed.some((a) => referer.startsWith(a + '/')))
  );
}

export function sameOriginProtect(
  req: Request,
  res: Response,
  next: NextFunction,
) {
  const method = (req.method || '').toUpperCase();
  if (method === 'GET' || method === 'HEAD' || method === 'OPTIONS') return next();

  if (!isAllowedRequestOrigin(req)) {
    return res.status(403).json({ message: 'BAD_ORIGIN' });
  }
  next();
}
