import { Body, Controller, Get, Post, Req, Res, UseGuards } from '@nestjs/common';
import type { Request, Response } from 'express';
import { AuthService } from './auth.service';
import { JwtAuthGuard } from './jwt.guard';
import { JwtService } from '@nestjs/jwt';
import { RefreshService } from './refresh.service';
import { isAllowedRequestOrigin } from '../security/origin';

function isHttps(req: Request): boolean {
  const xf = (req.headers['x-forwarded-proto'] as string | undefined) || '';
  return (req as any).secure === true || xf.split(',')[0].trim() === 'https';
}

function refreshMaxAgeMs(): number {
  const days = parseInt(process.env.JWT_REFRESH_EXPIRES_DAYS || '14', 10);
  const d = Number.isFinite(days) ? days : 14;
  return d * 24 * 60 * 60 * 1000;
}

function setRefreshCookie(req: Request, res: Response, token: string) {
  res.cookie('__Host-lsrt', token, {
    httpOnly: true,
    secure: isHttps(req),
    sameSite: 'lax',
    path: '/',
    maxAge: refreshMaxAgeMs(),
  });
}

@Controller('auth')
export class AuthController {
  constructor(
    private readonly auth: AuthService,
    private readonly jwt: JwtService,
    private readonly refresh: RefreshService,
  ) {}

  @Post('register')
  register(@Body() body: any) {
    // 不改变现有 register 行为（保持兼容）
    return this.auth.register(body.email, body.password);
  }

  @Post('login')
  async login(@Body() body: any, @Req() req: Request, @Res() res: Response) {
    // 统一 Origin 校验：浏览器必须匹配 allowlist；SSR/S2S 无 origin/referer 允许
    if (!isAllowedRequestOrigin(req)) {
      return res.status(401).json({ message: 'BAD_ORIGIN' });
    }

    const out: any = await this.auth.login(body.email, body.password);
    const accessToken = out?.accessToken;
    if (!accessToken) {
      return res.status(401).json({ message: 'UNAUTHORIZED' });
    }

    // 从 access token 解出 userId（避免改 AuthService 返回结构）
    const payload: any = this.jwt.verify(accessToken, { secret: process.env.JWT_SECRET });
    const userId: string | undefined = payload?.sub;
    if (!userId) {
      return res.status(401).json({ message: 'UNAUTHORIZED' });
    }

    // 写 DB refresh session + 生成 refresh token
    const issued: any = await this.refresh.issueRefreshSession(userId);
    const jti: string | undefined = typeof issued === 'string' ? issued : issued?.jti;
    if (!jti) {
      return res.status(500).json({ message: 'REFRESH_ISSUE_FAILED' });
    }

    const rt = this.refresh.createRefreshToken(userId, jti);
    setRefreshCookie(req, res, rt);

    // 保持原返回结构：只返回 accessToken
    return res.status(201).json({ accessToken });
  }

  @UseGuards(JwtAuthGuard)
  @Get('me')
  me(@Req() req: any) {
    return this.auth.me(req.user.userId);
  }
}
