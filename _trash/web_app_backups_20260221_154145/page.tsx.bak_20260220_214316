                <Signal
                  title="Refund Rate"
                  value={dash && dash.sales ? `${((Math.abs(dash.refunds) / dash.sales) * 100).toFixed(2)}%` : '-'}
                  note="MVP estimation"
                />
                <Signal
                  title="Ads Ratio"
                  value={dash && dash.sales ? `${((Math.abs(dash.ads) / dash.sales) * 100).toFixed(2)}%` : '-'}
                  note="MVP estimation"
                />
              </div>
            </div>
          </div>
        </div>

        {/* Transactions */}
        <div className="mt-6 rounded-2xl border bg-white">
          <div className="flex items-center justify-between px-5 py-4">
            <div>
              <div className="text-sm font-semibold">Transactions</div>
              <div className="mt-1 text-xs text-gray-500">Click delete to remove a record (MVP)</div>
            </div>
            <div className="text-sm text-gray-500">{dash ? `${dash.count} items` : ''}</div>
          </div>

          {/* Month Net Validation Bar */}
          <div className="px-5 pb-3 -mt-1">
            <div className="rounded-xl border bg-gray-50 px-4 py-2 text-xs text-gray-700 flex items-center justify-between">
              <span>
                Month Net (from transactions):
                <span className="ml-2 font-semibold tabular-nums">{fmtJPY(txSum)}</span>
              </span>
              <span>
                Dashboard Profit:
                <span className="ml-2 font-semibold tabular-nums">{dash ? fmtJPY(dash.profit) : '-'}</span>
              </span>
            </div>
          </div>

          <div className="overflow-x-auto border-t">
            <table className="w-full text-sm">
              <thead>
                <tr className="text-left text-xs text-gray-500">
                  <th className="px-5 py-3">Date</th>
                  <th className="px-5 py-3">Type</th>
                  <th className="px-5 py-3">Amount</th>
                  <th className="px-5 py-3">Memo</th>
                  <th className="px-5 py-3 text-right">Action</th>
                </tr>
              </thead>
              <tbody>
                {items.map((t) => (
                  <tr key={t.id} className="border-t hover:bg-gray-50">
                    <td className="px-5 py-3 tabular-nums">{t.occurredAt.slice(0, 10)}</td>
                    <td className="px-5 py-3">
                      <span className={typeBadgeClass(t.type)}>{typeLabel(t.type)}</span>
                    </td>
                    <td className={clsx('px-5 py-3 tabular-nums font-medium', t.amount < 0 ? 'text-gray-700' : 'text-gray-900')}>
                      {fmtJPY(t.amount)}
                    </td>
                    <td className="px-5 py-3 text-gray-700">{t.memo || ''}</td>
                    <td className="px-5 py-3 text-right">
                      <button className="rounded-lg border px-3 py-1.5 text-xs hover:bg-gray-50" onClick={() => deleteTx(t.id)}>
                        Delete
                      </button>
                    </td>
                  </tr>
                ))}

                {!items.length && (
                  <tr>
                    <td className="px-5 py-10 text-center text-gray-500" colSpan={5}>
                      <div className="mx-auto max-w-md">
                        <div className="text-sm font-semibold text-gray-800">No transactions yet</div>
                        <div className="mt-1 text-xs text-gray-500">Use Quick Add to create your first record. Next step will be CSV import.</div>
                      </div>
                    </td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>

          <div className="px-5 py-4 text-xs text-gray-500">
            Tips: SALE 为正；FBA/AD/REFUND 自动负数。CSV 导入 MVP：支持模板 CSV（date,type,amount,memo）。
          </div>
        </div>

        {/* CSV Import MVP */}
        <div className="mt-6 rounded-2xl border bg-white p-5">
          <div className="flex items-center justify-between">
            <div>
              <div className="text-sm font-semibold">CSV Import (MVP)</div>
              <div className="mt-1 text-xs text-gray-500">
                Supported: LedgerSeiri template CSV columns: <code>date,type,amount,memo</code>
              </div>
            </div>
          </div>

          <div className="mt-4 grid gap-3 md:grid-cols-12">
            <div className="md:col-span-6">
              <div className="rounded-xl border bg-gray-50 p-4">
                <div className="text-xs text-gray-600">1) Choose CSV</div>
                <input
                  className="mt-2 w-full rounded-xl border bg-white px-3 py-2 text-sm"
                  type="file"
                  accept=".csv,text/csv"
                  onChange={(e) => onPickCsv(e.target.files?.[0] ?? null)}
                />
                <div className="mt-2 text-[11px] text-gray-500">Selected: {csvName || '(none)'}</div>

                <div className="mt-3 text-xs text-gray-600">2) Preview</div>
                <div className="mt-2 text-[11px] text-gray-500">
                  {parsed ? `Format: ${parsed.format} | Rows: ${parsed.items.length} | Sum: ${fmtJPY(previewSum)}` : 'No parsed data yet.'}
                </div>

                <button
                  className="mt-3 w-full rounded-xl bg-black px-4 py-2 text-sm font-semibold text-white hover:opacity-90 disabled:opacity-50"
                  disabled={!storeId || !parsed || parsed.format !== 'LEDGERSEIRI' || !parsed.items.length || importing}
                  onClick={doImport}
                >
                  {importing ? 'Importing...' : '3) Import to LedgerSeiri'}
                </button>

                {parsed?.warnings?.length ? (
                  <div className="mt-3 rounded-xl border bg-white p-3 text-xs text-gray-700">
                    <div className="font-semibold">Warnings</div>
                    <ul className="mt-2 list-disc pl-5">
                      {parsed.warnings.map((w, i) => (
                        <li key={i}>{w}</li>
                      ))}
                    </ul>
                  </div>
                ) : null}
              </div>
            </div>

            <div className="md:col-span-6">
              <div className="rounded-xl border bg-gray-50 p-4">
                <div className="text-xs text-gray-600">Preview table (first 200 rows)</div>
                <div className="mt-3 overflow-x-auto rounded-xl border bg-white">
                  <table className="w-full text-sm">
                    <thead>
                      <tr className="text-left text-xs text-gray-500">
                        <th className="px-3 py-2">Date</th>
                        <th className="px-3 py-2">Type</th>
                        <th className="px-3 py-2">Amount</th>
                        <th className="px-3 py-2">Memo</th>
                      </tr>
                    </thead>
                    <tbody>
                      {previewItems.map((it, idx) => (
                        <tr key={idx} className="border-t">
                          <td className="px-3 py-2 tabular-nums">{it.occurredAt.slice(0, 10)}</td>
                          <td className="px-3 py-2">
                            <span className={typeBadgeClass(it.type)}>{typeLabel(it.type)}</span>
                          </td>
                          <td className="px-3 py-2 tabular-nums">{fmtJPY(it.amount)}</td>
                          <td className="px-3 py-2 text-gray-700">{it.memo || ''}</td>
                        </tr>
                      ))}
                      {!previewItems.length && (
                        <tr>
                          <td className="px-3 py-8 text-center text-gray-500" colSpan={4}>
                            No preview data. Upload CSV first.
                          </td>
                        </tr>
                      )}
                    </tbody>
                  </table>
                </div>

                <div className="mt-3 text-xs text-gray-500">
                  Template example:
                  <pre className="mt-2 overflow-auto rounded-xl border bg-white p-3 text-[11px] text-gray-700">
{`date,type,amount,memo
2026-02-20,SALE,10000,order A
2026-02-20,FBA_FEE,1200,fba fee
2026-02-20,AD,500,ads
2026-02-21,REFUND,200,refund`}
                  </pre>
                </div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  );
}

function KpiCard({ title, value, hint }: { title: string; value: string; hint: string }) {
  return (
    <div className="rounded-2xl border bg-white p-5">
      <div className="flex items-start justify-between">
        <div>
          <div className="text-xs text-gray-500">{title}</div>
          <div className="mt-2 text-2xl font-bold tracking-tight">{value}</div>
          <div className="mt-1 text-xs text-gray-500">{hint}</div>
        </div>
        <div className="rounded-xl border bg-gray-50 px-2.5 py-1.5 text-xs text-gray-600">M</div>
      </div>
    </div>
  );
}

function MiniStat({ label, value }: { label: string; value: string }) {
  return (
    <div className="rounded-xl border bg-gray-50 p-3">
      <div className="text-[11px] text-gray-500">{label}</div>
      <div className="mt-1 text-sm font-semibold tabular-nums text-gray-900">{value}</div>
    </div>
  );
}

function Signal({ title, value, note }: { title: string; value: string; note: string }) {
  return (
    <div className="rounded-2xl border bg-gray-50 p-4">
      <div className="text-xs text-gray-500">{title}</div>
      <div className="mt-2 text-lg font-bold tabular-nums">{value}</div>
      <div className="mt-1 text-xs text-gray-500">{note}</div>
    </div>
  );
}
