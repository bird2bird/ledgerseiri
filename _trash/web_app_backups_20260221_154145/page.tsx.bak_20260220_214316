  type: 'SALE' | 'FBA_FEE' | 'AD' | 'REFUND' | 'OTHER';
  amount: number;
  currency: string;
  occurredAt: string;
  memo: string | null;
  createdAt: string;
};

type ImportItem = { type: Tx['type']; amount: number; occurredAt: string; memo?: string | null };
type Parsed = { format: 'LEDGERSEIRI' | 'UNKNOWN'; items: ImportItem[]; warnings: string[] };

const LS_STORE_KEY = 'ls_storeId';
const LS_MONTH_KEY = 'ls_month';

function ymNowTokyo(): string {
  const d = new Date();
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, '0');
  return `${y}-${m}`;
}

function fmtJPY(n: number) {
  return new Intl.NumberFormat('ja-JP', { style: 'currency', currency: 'JPY' }).format(n);
}

function normalizeAmount(type: Tx['type'], amount: number): number {
  const abs = Math.abs(Number(amount || 0));
  if (type === 'SALE') return abs;
  if (type === 'FBA_FEE' || type === 'AD' || type === 'REFUND') return -abs;
  return Number(amount || 0);
}

function toOccurredAtISO(dateInput: string): string {
  // Robust date parser:
  // - trim, remove invisible chars
  // - convert full-width digits to half-width
  // - accept: YYYY-MM-DD, YYYY/MM/DD, YYYY-MM-DD HH:mm, YYYY/MM/DD HH:mm
  const fw = '０１２３４５６７８９';
  let x = (dateInput || '')
    .replace(/[\u200B-\u200D\uFEFF]/g, '') // invisible chars
    .trim();

  // full-width -> half-width
  x = x
    .split('')
    .map((ch) => {
      const i = fw.indexOf(ch);
      return i >= 0 ? String(i) : ch;
    })
    .join('');

  // normalize separators, allow date-time, take first 10 chars
  x = x.replace(/\./g, '-').replace(/\//g, '-');
  if (x.length >= 10) x = x.slice(0, 10);

  const m = x.match(/^(\d{4})-(\d{1,2})-(\d{1,2})$/);
  if (!m) throw new Error(`Invalid date format: "${dateInput}"`);

  const y = Number(m[1]);
  const mo = String(Number(m[2])).padStart(2, '0');
  const d = String(Number(m[3])).padStart(2, '0');
  const iso = `${y}-${mo}-${d}T00:00:00.000Z`;

  const dt = new Date(iso);
  if (Number.isNaN(dt.getTime())) throw new Error(`Invalid time value from date: "${dateInput}"`);
  return dt.toISOString();
}


function clsx(...xs: Array<string | false | null | undefined>) {
  return xs.filter(Boolean).join(' ');
}

function typeLabel(t: Tx['type']) {
  switch (t) {
    case 'SALE':
      return 'Sale';
    case 'FBA_FEE':
      return 'FBA Fee';
    case 'AD':
      return 'Ads';
    case 'REFUND':
      return 'Refund';
    default:
      return 'Other';
  }
}

function typeBadgeClass(t: Tx['type']) {
  const base = 'inline-flex items-center rounded-full border px-2 py-0.5 text-xs';
  if (t === 'SALE') return `${base} bg-white`;
  return `${base} bg-gray-50`;
}

// Daily net series (visual only)
function buildDailyNetSeries(items: Tx[]) {
  const m = new Map<string, number>();
  for (const t of items) {
    const d = t.occurredAt.slice(0, 10);
    m.set(d, (m.get(d) || 0) + t.amount);
  }
  const keys = Array.from(m.keys()).sort();
  const vals = keys.map((k) => m.get(k) || 0);
  return { dates: keys.slice(-14), values: vals.slice(-14) };
}

function Sparkline({ values }: { values: number[] }) {
  const w = 160;
  const h = 36;
  if (!values.length) return <div className="h-9 w-40 rounded-lg bg-gray-50" />;
  const min = Math.min(...values);
  const max = Math.max(...values);
  const span = max - min || 1;
  const pts = values
    .map((v, i) => {
      const x = (i / Math.max(1, values.length - 1)) * (w - 6) + 3;
      const y = h - ((v - min) / span) * (h - 6) - 3;
      return `${x.toFixed(1)},${y.toFixed(1)}`;
    })
    .join(' ');
  return (
    <svg width={w} height={h} viewBox={`0 0 ${w} ${h}`} className="block">
      <polyline fill="none" stroke="currentColor" strokeWidth="2" points={pts} className="text-gray-900" />
      <polyline fill="none" stroke="currentColor" strokeWidth="8" strokeLinecap="round" points={pts} className="text-gray-900/10" />
    </svg>
  );
}

/** ===== CSV Parse (MVP) =====
 * Supports:
 * - LedgerSeiri template: date,type,amount,memo
 * delimiter: comma or tab
 * quotes: "..."
 */
function parseCsv(text: string): { header: string[]; rows: string[][] } {
  const lines = text.replace(/\r\n/g, '\n').replace(/\r/g, '\n').split('\n').filter((l) => l.trim().length);
  if (!lines.length) return { header: [], rows: [] };

  const sample = lines[0];
  const delimiter = sample.includes('\t') && !sample.includes(',') ? '\t' : ',';

  const parseLine = (line: string) => {
    const out: string[] = [];
    let cur = '';
    let inQuotes = false;
    for (let i = 0; i < line.length; i++) {
      const ch = line[i];
      if (ch === '"') {
        if (inQuotes && line[i + 1] === '"') {
          cur += '"';
          i++;
        } else {
          inQuotes = !inQuotes;
        }
        continue;
      }
      if (!inQuotes && ch === delimiter) {
        out.push(cur);
        cur = '';
        continue;
      }
      cur += ch;
    }
    out.push(cur);
    return out.map((s) => s.trim());
  };

  const header = parseLine(lines[0]).map((h) => h.replace(/^\uFEFF/, '').trim());
  const rows = lines.slice(1).map(parseLine);
  return { header, rows };
}

function detectAndConvert(csvText: string): Parsed {
  const { header, rows } = parseCsv(csvText);
  const warnings: string[] = [];
  if (!header.length) return { format: 'UNKNOWN', items: [], warnings: ['CSV header not found'] };

  const lower = header.map((h) => h.toLowerCase());

  const hasLedgerSeiri = lower.includes('date') && lower.includes('type') && lower.includes('amount');

  if (!hasLedgerSeiri) {
    return {
      format: 'UNKNOWN',
      items: [],
      warnings: [
        'Unknown CSV format.',
        'Supported format:',
        'LedgerSeiri template CSV columns: date,type,amount,memo',
      ],
    };
  }

  const idxDate = lower.indexOf('date');
  const idxType = lower.indexOf('type');
  const idxAmount = lower.indexOf('amount');
  const idxMemo = lower.indexOf('memo');

  const items: ImportItem[] = [];
  for (let i = 0; i < rows.length; i++) {
    const r = rows[i];
    const dateRaw = (r[idxDate] || '').trim();
    const type = ((r[idxType] || 'OTHER').trim() as any) as Tx['type'];
    const amount = Number(String(r[idxAmount] || '0').replace(/,/g, ''));
    const memo = idxMemo >= 0 ? (r[idxMemo] || '').trim() : '';

    if (!dateRaw) continue;

    if (!['SALE', 'FBA_FEE', 'AD', 'REFUND', 'OTHER'].includes(type)) {
      warnings.push(`Row ${i + 2}: Unknown type "${type}" -> treated as OTHER`);
    }
    const t = (['SALE', 'FBA_FEE', 'AD', 'REFUND', 'OTHER'].includes(type) ? type : 'OTHER') as Tx['type'];

    try {
      const occurredAt = toOccurredAtISO(dateRaw);
      items.push({
        type: t,
        amount: normalizeAmount(t, amount),
        occurredAt,
        memo: memo || null,
      });
    } catch (e: any) {
      warnings.push(`Row ${i + 2}: ${e?.message ?? String(e)}`);
      // skip bad row
    }
  }

  if (!items.length) warnings.push('No rows converted. Check date/type/amount columns.');
  return { format: 'LEDGERSEIRI', items, warnings };
}

export default function AppHome() {
  const router = useRouter();
  const [token, setToken] = useState<string | null>(null);

  const [company, setCompany] = useState<CompanyResp['company']>(null);
  const [stores, setStores] = useState<CompanyResp['stores']>([]);
  const [storeId, setStoreId] = useState<string>('');
  const [month, setMonth] = useState<string>(ymNowTokyo());

  const [dash, setDash] = useState<Dashboard | null>(null);
  const [items, setItems] = useState<Tx[]>([]);
  const [err, setErr] = useState<string | null>(null);

  // Quick Add
  const [type, setType] = useState<Tx['type']>('SALE');
  const [amount, setAmount] = useState<number>(10000);
  const [memo, setMemo] = useState<string>('first sale');
  const [date, setDate] = useState<string>(() => {
    const d = new Date();
    const yyyy = d.getFullYear();
    const mm = String(d.getMonth() + 1).padStart(2, '0');
    const dd = String(d.getDate()).padStart(2, '0');
    return `${yyyy}-${mm}-${dd}`;
  });
  const [creating, setCreating] = useState(false);

  // CSV Import
  const [csvName, setCsvName] = useState<string>('');
  const [parsed, setParsed] = useState<Parsed | null>(null);
  const [importing, setImporting] = useState(false);
  const [importOk, setImportOk] = useState<string | null>(null);

  useEffect(() => {
    const t = localStorage.getItem('ls_token');
    if (!t) {
      router.push('/login');
      return;
    }
    setToken(t);

    const savedStoreId = localStorage.getItem(LS_STORE_KEY);
    const savedMonth = localStorage.getItem(LS_MONTH_KEY);
    if (savedMonth) setMonth(savedMonth);
    if (savedStoreId) setStoreId(savedStoreId);
  }, [router]);

  async function apiGet<T>(path: string): Promise<T> {
    const res = await fetch(path, {
      headers: token ? { Authorization: `Bearer ${token}` } : {},
      cache: 'no-store',
    });
    if (!res.ok) {
      const text = await res.text();
      throw new Error(`${path} failed: ${res.status} ${text}`);
    }
    return (await res.json()) as T;
  }

  async function apiPost<T>(path: string, body: any): Promise<T> {
    const res = await fetch(path, {
      method: 'POST',
      headers: {
        ...(token ? { Authorization: `Bearer ${token}` } : {}),
        'Content-Type': 'application/json',
      },
      body: JSON.stringify(body),
    });
    if (!res.ok) {
      const text = await res.text();
      throw new Error(`${path} failed: ${res.status} ${text}`);
    }
    return (await res.json()) as T;
  }

  async function apiDel<T>(path: string): Promise<T> {
    const res = await fetch(path, {
      method: 'DELETE',
      headers: token ? { Authorization: `Bearer ${token}` } : {},
    });
    if (!res.ok) {
      const text = await res.text();
      throw new Error(`${path} failed: ${res.status} ${text}`);
    }
    return (await res.json()) as T;
  }

  // company + stores
  useEffect(() => {
    if (!token) return;
    (async () => {
      setErr(null);
      try {
        const data = await apiGet<CompanyResp>('/api/company');
        setCompany(data.company);
        setStores(data.stores || []);
        if (!storeId && data.stores?.length) setStoreId(data.stores[0].id);
      } catch (e: any) {
        setErr(e?.message ?? String(e));
      }
    })();
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, [token]);

  useEffect(() => {
    if (storeId) localStorage.setItem(LS_STORE_KEY, storeId);
  }, [storeId]);

  useEffect(() => {
    if (month) localStorage.setItem(LS_MONTH_KEY, month);
  }, [month]);

  // dashboard + transactions
  useEffect(() => {
    if (!token || !storeId || !month) return;
    (async () => {
      setErr(null);
      try {
        const d = await apiGet<Dashboard>(
          `/api/dashboard?storeId=${encodeURIComponent(storeId)}&month=${encodeURIComponent(month)}`
        );
        setDash(d);
        const t = await apiGet<{ items: Tx[] }>(
          `/api/transaction?storeId=${encodeURIComponent(storeId)}&month=${encodeURIComponent(month)}`
        );
        setItems(t.items || []);
      } catch (e: any) {
        setErr(e?.message ?? String(e));
      }
    })();
  }, [token, storeId, month]);

  async function refresh() {
    if (!token || !storeId || !month) return;
    const d = await apiGet<Dashboard>(
      `/api/dashboard?storeId=${encodeURIComponent(storeId)}&month=${encodeURIComponent(month)}`
    );
    setDash(d);
    const t = await apiGet<{ items: Tx[] }>(
      `/api/transaction?storeId=${encodeURIComponent(storeId)}&month=${encodeURIComponent(month)}`
    );
    setItems(t.items || []);
  }

  function logout() {
    localStorage.removeItem('ls_token');
    router.push('/login');
  }

  async function createTx() {
    if (!storeId) return;
    setCreating(true);
    setErr(null);
    try {
      const occurredAt = toOccurredAtISO(date);
      const fixedAmount = normalizeAmount(type, amount);

      await apiPost<Tx>('/api/transaction', {
        storeId,
        type,
        amount: fixedAmount,
        occurredAt,
        memo: memo || null,
      });

      await refresh();
    } catch (e: any) {
      setErr(e?.message ?? String(e));
    } finally {
      setCreating(false);
    }
  }

  async function deleteTx(id: string) {
    setErr(null);
    try {
      await apiDel<{ ok: boolean }>(`/api/transaction/${id}`);
      await refresh();
    } catch (e: any) {
      setErr(e?.message ?? String(e));
    }
  }

  // CSV: pick file -> parse -> preview
  async function onPickCsv(file: File | null) {
    setErr(null);
    setImportOk(null);
    setParsed(null);
    setCsvName('');
    if (!file) return;

    setCsvName(file.name);
    try {
      // Some Windows/Excel CSV may break File.text() decoding; catch and show error
      const text = await file.text();
      const p = detectAndConvert(text);
      setParsed(p);
    } catch (e: any) {
      const msg = e?.message ?? String(e);
      setErr(
        `CSV read/parse failed: ${msg}. Please save CSV as UTF-8 and ensure header is: date,type,amount,memo`
      );
      setParsed({
        format: 'UNKNOWN',
        items: [],
        warnings: ['CSV read/parse failed. Save as UTF-8. Header must be: date,type,amount,memo'],
      });
    }
  }


  async function doImport() {
    if (!storeId || !parsed || !parsed.items.length) return;
    setImporting(true);
    setErr(null);
    setImportOk(null);
    try {
      const res = await apiPost<{ ok: boolean; created: number }>('/api/transaction/bulk', {
        storeId,
        items: parsed.items,
      });
      setImportOk(`Imported: ${res.created} rows`);
      await refresh();
    } catch (e: any) {
      setErr(e?.message ?? String(e));
    } finally {
      setImporting(false);
    }
  }

  const series = useMemo(() => buildDailyNetSeries(items), [items]);

  const profitMargin = useMemo(() => {
    if (!dash) return null;
    if (!dash.sales) return 0;
    return (dash.profit / dash.sales) * 100;
  }, [dash]);

  const txSum = useMemo(() => items.reduce((a, b) => a + b.amount, 0), [items]);

  const previewItems = useMemo(() => (parsed?.items || []).slice(0, 200), [parsed]);
  const previewSum = useMemo(() => (parsed?.items || []).reduce((a, b) => a + b.amount, 0), [parsed]);

  return (
    <div className="min-h-screen bg-gray-50">
      {/* Top header */}
      <div className="sticky top-0 z-10 border-b bg-white/80 backdrop-blur">
        <div className="mx-auto max-w-6xl px-6 py-4">
          <div className="flex items-center justify-between gap-4">
            <div>
              <div className="text-xs text-gray-500">LedgerSeiri / App</div>
              <div className="mt-1 flex items-baseline gap-3">
                <h1 className="text-xl font-bold tracking-tight">Dashboard</h1>
                <div className="text-sm text-gray-600">
                  {company ? `Company: ${company.name}` : 'Company: (loading...)'}
                </div>
              </div>
            </div>

            <div className="flex items-center gap-2">
              <a className="rounded-xl border bg-white px-3 py-2 text-sm hover:bg-gray-50" href="/lp">
                LP
              </a>
              <button className="rounded-xl border bg-white px-3 py-2 text-sm hover:bg-gray-50" onClick={logout}>
                Logout
              </button>
            </div>
          </div>

          {/* Filters row */}
          <div className="mt-4 grid gap-3 md:grid-cols-12">
            <div className="md:col-span-5">
              <div className="rounded-2xl border bg-white p-4">
                <div className="flex items-center justify-between">
                  <div className="text-sm font-semibold">Store</div>
                  <div className="text-xs text-gray-500">saved</div>
                </div>
                <select
                  className="mt-2 w-full rounded-xl border px-3 py-2 text-sm"
                  value={storeId}
                  onChange={(e) => setStoreId(e.target.value)}
                >
                  {stores.map((s) => (
                    <option key={s.id} value={s.id}>
                      {s.name} ({s.platform}-{s.region})
                    </option>
                  ))}
                </select>
                <div className="mt-2 text-[11px] text-gray-500 break-all">{storeId || '(none)'}</div>
              </div>
            </div>

            <div className="md:col-span-3">
              <div className="rounded-2xl border bg-white p-4">
                <div className="flex items-center justify-between">
                  <div className="text-sm font-semibold">Month</div>
                  <div className="text-xs text-gray-500">YYYY-MM</div>
                </div>
                <input
                  className="mt-2 w-full rounded-xl border px-3 py-2 text-sm"
                  value={month}
                  onChange={(e) => setMonth(e.target.value)}
                  placeholder="2026-02"
                />
                <div className="mt-2 text-[11px] text-gray-500">saved to localStorage</div>
              </div>
            </div>

            {/* Quick add panel */}
            <div className="md:col-span-4">
              <div className="rounded-2xl border bg-white p-4">
                <div className="flex items-center justify-between">
                  <div className="text-sm font-semibold">Quick Add</div>
                  <div className="text-xs text-gray-500">1-click bookkeeping</div>
                </div>

                <div className="mt-3 grid grid-cols-2 gap-2">
                  <select className="rounded-xl border px-3 py-2 text-sm" value={type} onChange={(e) => setType(e.target.value as any)}>
                    <option value="SALE">SALE (+)</option>
                    <option value="FBA_FEE">FBA_FEE (-)</option>
                    <option value="AD">AD (-)</option>
                    <option value="REFUND">REFUND (-)</option>
                    <option value="OTHER">OTHER (+/-)</option>
                  </select>

                  <input className="rounded-xl border px-3 py-2 text-sm" type="number" value={amount} onChange={(e) => setAmount(Number(e.target.value))} />

                  <input className="rounded-xl border px-3 py-2 text-sm" value={date} onChange={(e) => setDate(e.target.value)} />

                  <input className="rounded-xl border px-3 py-2 text-sm" value={memo} onChange={(e) => setMemo(e.target.value)} placeholder="memo" />
                </div>

                <div className="mt-2 flex items-center justify-between text-[11px] text-gray-500">
                  <span>
                    will save: <span className="font-semibold text-gray-900">{fmtJPY(normalizeAmount(type, amount))}</span>
                  </span>
                  <span className="tabular-nums">{toOccurredAtISO(date)}</span>
                </div>

                <button className="mt-3 w-full rounded-xl bg-black px-4 py-2 text-sm font-semibold text-white hover:opacity-90 disabled:opacity-50" disabled={!storeId || !month || creating} onClick={createTx}>
                  {creating ? 'Saving...' : 'Add Transaction'}
