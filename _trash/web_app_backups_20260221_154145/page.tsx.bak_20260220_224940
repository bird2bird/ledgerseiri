            <KpiCell title="FBA Fees" value={fmtJPY(fbaFees)} emphasis="neg" />
            <KpiCell title="Ads" value={fmtJPY(ads)} emphasis="neg" />
            <KpiCell title="Refunds" value={fmtJPY(refunds)} emphasis="neg" />
