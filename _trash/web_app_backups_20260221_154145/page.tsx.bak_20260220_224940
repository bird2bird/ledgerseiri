          <div className="mt-4 grid gap-4 lg:grid-cols-2">
            <Card className="p-4">
              <div className="text-sm font-semibold text-gray-900">1) Choose CSV</div>
              <input
                className="mt-2 block w-full rounded-xl border border-gray-200 bg-white px-3 py-2"
                type="file"
                accept=".csv,text/csv"
                onChange={(e) => onChooseCsv(e.target.files?.[0] ?? null)}
              />
              <div className="mt-2 text-xs text-gray-500">Selected: {csvFileName || '(none)'}</div>

              <div className="mt-4 text-sm font-semibold text-gray-900">2) Preview</div>
              <div className="mt-2 text-xs text-gray-500">
                Format: <span className="font-semibold text-gray-900">{csvFormat}</span> | Rows: <span className="font-semibold text-gray-900">{csvRows.length}</span> | Sum: <span className="font-semibold text-gray-900">{fmtJPY(csvRows.reduce((a, r) => a + r.amount, 0))}</span>
              </div>

              <button
                className="mt-4 w-full rounded-xl bg-indigo-600 hover:bg-indigo-700 px-4 py-2.5 text-white font-medium disabled:opacity-50"
                disabled={!storeId || !csvRows.length || importing || csvFormat !== 'LEDGERSEIRI'}
                onClick={importCsv}
              >
                {importing ? 'Importing...' : '3) Import to LedgerSeiri'}
              </button>

              {csvWarnings.length > 0 && (
                <div className="mt-4 rounded-xl border border-amber-200 bg-amber-50 p-3 text-xs text-amber-800">
                  <div className="font-semibold mb-1">Warnings</div>
                  <ul className="list-disc pl-5">
                    {csvWarnings.slice(0, 10).map((w, idx) => (
                      <li key={idx}>{w}</li>
                    ))}
                    {csvWarnings.length > 10 && <li>... and more</li>}
                  </ul>
                </div>
              )}
            </Card>

            <Card className="p-4">
              <div className="text-sm font-semibold text-gray-900">Preview table (first 200 rows)</div>
              <div className="mt-3 overflow-x-auto">
                <table className="w-full text-sm">
                  <thead>
                    <tr className="text-left text-gray-500">
                      <th className="py-2 pr-3">Date</th>
                      <th className="py-2 pr-3">Type</th>
                      <th className="py-2 pr-3">Amount</th>
                      <th className="py-2 pr-3">Memo</th>
                    </tr>
                  </thead>
                  <tbody>
                    {previewRows.map((r, idx) => (
                      <tr key={idx} className="border-t border-gray-100">
                        <td className="py-2 pr-3">{r.date}</td>
                        <td className="py-2 pr-3">
                          <Pill>{r.type}</Pill>
                        </td>
                        <td className="py-2 pr-3 font-medium text-gray-900">{fmtJPY(r.amount)}</td>
                        <td className="py-2 pr-3 text-gray-700">{r.memo}</td>
                      </tr>
                    ))}
                    {!previewRows.length && (
                      <tr>
                        <td className="py-6 text-center text-gray-500" colSpan={4}>
                          No preview data. Upload CSV first.
                        </td>
                      </tr>
                    )}
                  </tbody>
                </table>
              </div>

              <div className="mt-4 text-xs text-gray-500">Template example:</div>
              <pre className="mt-2 whitespace-pre-wrap rounded-xl border border-gray-200 bg-gray-50 p-3 text-xs text-gray-800">
date,type,amount,memo
2026-02-20,SALE,10000,order A
2026-02-20,FBA_FEE,1200,fba fee
2026-02-20,AD,500,ads
2026-02-21,REFUND,200,refund
              </pre>
              <div className="mt-2 text-[11px] text-gray-500">
                Note: MVP CSV parser doesn’t support quoted commas. Keep memo simple.
              </div>
            </Card>
          </div>
        </Card>

        <div className="mt-10 text-xs text-gray-400">
          LedgerSeiri MVP — next: categories, Amazon CSV importer, receipts OCR.
        </div>
      </div>
    </div>
  );
}

function KpiCell({ title, value, emphasis }: { title: string; value: string; emphasis: 'pos' | 'neg' }) {
  const color = emphasis === 'neg' ? 'text-red-600' : 'text-gray-900';
  return (
    <div className="p-6 text-center">
      <div className="text-xs text-gray-500">{title}</div>
      <div className={`mt-2 text-2xl font-semibold ${color}`}>{value}</div>
    </div>
  );
}
